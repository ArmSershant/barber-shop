// Barber-Shop — Prisma schema
// Source of truth for the database. See docs/02-data-model.md for rationale.
//
// Notes:
// - UUID PKs via gen_random_uuid() (pgcrypto).
// - All timestamps are timestamptz, stored UTC.
// - Working hours stored as minutes-from-midnight (0..1439) in the barber's
//   timezone — simpler and safer for slot math than a `time` column.
// - The "no double-booking" guarantee is a GiST EXCLUDE constraint that Prisma
//   cannot express; it is added by a raw-SQL step in the init migration
//   (see prisma/migrations/.../migration.sql and docs/03 §7.2).
// - Field names are camelCase in Prisma and mapped to snake_case columns/tables.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, btree_gist, citext, pg_trgm]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserStatus {
  active
  suspended
}

enum Role {
  customer
  barber
  shop_owner
  admin
}

enum ProviderStatus {
  pending
  active
  suspended
}

enum BookingStatus {
  requested
  confirmed
  cancelled
  completed
  no_show
}

enum CancelledBy {
  customer
  provider
  system
}

enum NotificationChannel {
  email
  inapp
  telegram
  push
  sms
}

enum NotificationType {
  booking_created
  booking_confirmed
  booking_cancelled
  reminder
  review_request
  review_received
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
}

enum RequestStatus {
  pending
  approved
  rejected
}

enum RequestActor {
  barber
  owner
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique @db.Citext
  passwordHash  String?    @map("password_hash")
  fullName      String     @map("full_name")
  phone         String?
  phoneVerified Boolean    @default(false) @map("phone_verified")
  emailVerified Boolean    @default(false) @map("email_verified")
  avatarUrl     String?    @map("avatar_url")
  status        UserStatus @default(active)
  preferredDistrictId Int? @map("preferred_district_id") @db.SmallInt
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?  @map("deleted_at") @db.Timestamptz(6)

  roles         UserRole[]
  ownedShops    Shop[]         @relation("ShopOwner")
  barberProfile Barber?        @relation("BarberUser")
  bookings      Booking[]      @relation("CustomerBookings")
  reviews       Review[]
  notifications Notification[]
  favorites     Favorite[]
  refreshTokens RefreshToken[]

  @@map("users")
}

// Opaque rotating refresh tokens. We store only a SHA-256 hash of the raw token.
// Rotation: on use, the old row is revoked and linked to its replacement.
// Reuse detection: presenting an already-revoked token revokes the whole chain.
model RefreshToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedById String?   @map("replaced_by_id") @db.Uuid
  userAgent    String?   @map("user_agent")
  ip           String?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  role   Role
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Location lookup
// ---------------------------------------------------------------------------

model District {
  id      Int      @id @default(autoincrement()) @db.SmallInt
  nameHy  String   @map("name_hy")
  nameEn  String   @map("name_en")
  slug    String   @unique
  shops   Shop[]
  barbers Barber[]

  @@map("districts")
}

// ---------------------------------------------------------------------------
// Providers
// ---------------------------------------------------------------------------

model Shop {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId String         @map("owner_user_id") @db.Uuid
  name        String
  slug        String         @unique
  description String?
  logoUrl     String?        @map("logo_url")
  districtId  Int?           @map("district_id") @db.SmallInt
  address     String?
  lat         Decimal?       @db.Decimal(9, 6)
  lng         Decimal?       @db.Decimal(9, 6)
  phone       String?
  instagram   String?
  status      ProviderStatus @default(pending)
  // Copy-on-apply templates: arrays of {weekday,startMinute,endMinute}.
  defaultWorkingHours Json   @default("[]") @map("default_working_hours")
  defaultBreaks       Json   @default("[]") @map("default_breaks")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz(6)

  owner    User        @relation("ShopOwner", fields: [ownerUserId], references: [id])
  district District?   @relation(fields: [districtId], references: [id])
  barbers  Barber[]
  services Service[]
  photos   ShopPhoto[]
  bookings Booking[]

  @@index([districtId, status])
  @@map("shops")
}

model Barber {
  id                 String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId             String?        @map("shop_id") @db.Uuid
  userId             String?        @unique @map("user_id") @db.Uuid
  displayName        String         @map("display_name")
  slug               String         @unique
  bio                String?
  experienceYears    Int?           @map("experience_years") @db.SmallInt
  photoUrl           String?        @map("photo_url")
  districtId         Int?           @map("district_id") @db.SmallInt
  timezone           String         @default("Asia/Yerevan")
  slotGranularityMin Int            @default(15) @map("slot_granularity_min") @db.SmallInt
  defaultBufferMin   Int            @default(0) @map("default_buffer_min") @db.SmallInt
  isVerified         Boolean        @default(false) @map("is_verified")
  status             ProviderStatus @default(pending)
  ratingAvg          Decimal        @default(0) @map("rating_avg") @db.Decimal(2, 1)
  ratingCount        Int            @default(0) @map("rating_count")
  createdAt          DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?      @map("deleted_at") @db.Timestamptz(6)

  shop            Shop?            @relation(fields: [shopId], references: [id])
  user            User?            @relation("BarberUser", fields: [userId], references: [id])
  district        District?        @relation(fields: [districtId], references: [id])
  ownedServices   Service[]        @relation("BarberOwnedServices")
  barberServices  BarberService[]
  workingHours    WorkingHours[]
  timeOff         TimeOff[]
  breaks          Break[]
  bookings        Booking[]
  reviews         Review[]
  portfolioImages PortfolioImage[]
  favorites       Favorite[]

  @@index([districtId, status])
  @@index([ratingAvg(sort: Desc)])
  @@map("barbers")
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Service {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId        String?  @map("shop_id") @db.Uuid
  ownerBarberId String?  @map("owner_barber_id") @db.Uuid
  // Canonical catalog key (lib/service-types.ts); null = legacy free-text row.
  type          String?
  name          String
  description   String?
  durationMin   Int      @map("duration_min") @db.SmallInt
  priceAmd      Int      @map("price_amd")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  shop           Shop?            @relation(fields: [shopId], references: [id])
  ownerBarber    Barber?          @relation("BarberOwnedServices", fields: [ownerBarberId], references: [id])
  barberServices BarberService[]
  bookingItems   BookingService[]

  @@index([shopId])
  @@index([ownerBarberId])
  @@map("services")
}

model BarberService {
  barberId            String  @map("barber_id") @db.Uuid
  serviceId           String  @map("service_id") @db.Uuid
  priceAmdOverride    Int?    @map("price_amd_override")
  durationMinOverride Int?    @map("duration_min_override") @db.SmallInt

  barber  Barber  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([barberId, serviceId])
  @@map("barber_services")
}

// ---------------------------------------------------------------------------
// Schedule
// ---------------------------------------------------------------------------

// Recurring weekly template. weekday: 0=Mon .. 6=Sun.
// Times are minutes-from-midnight (0..1439) in the barber's timezone.
// Multiple rows per weekday allowed (split shifts).
model WorkingHours {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barberId    String @map("barber_id") @db.Uuid
  weekday     Int    @db.SmallInt
  startMinute Int    @map("start_minute") @db.SmallInt
  endMinute   Int    @map("end_minute") @db.SmallInt

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, weekday])
  @@map("working_hours")
}

// One-off unavailable blocks: holidays, vacation, breaks.
model TimeOff {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barberId    String        @map("barber_id") @db.Uuid
  startsAt    DateTime      @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime      @map("ends_at") @db.Timestamptz(6)
  reason      String?
  status      RequestStatus @default(approved)
  requestedBy RequestActor  @default(barber) @map("requested_by")
  decidedById String?       @map("decided_by_id") @db.Uuid
  decidedAt   DateTime?     @map("decided_at") @db.Timestamptz(6)

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, startsAt])
  @@map("time_off")
}

// Recurring breaks. weekday null = every working day; 0=Mon..6=Sun otherwise.
model Break {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barberId    String        @map("barber_id") @db.Uuid
  weekday     Int?          @db.SmallInt
  startMinute Int           @map("start_minute") @db.SmallInt
  endMinute   Int           @map("end_minute") @db.SmallInt
  status      RequestStatus @default(approved)
  requestedBy RequestActor  @default(barber) @map("requested_by")
  decidedById String?       @map("decided_by_id") @db.Uuid
  decidedAt   DateTime?     @map("decided_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId])
  @@map("breaks")
}

// ---------------------------------------------------------------------------
// Bookings
// ---------------------------------------------------------------------------

model Booking {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerUserId   String?       @map("customer_user_id") @db.Uuid
  guestName        String?       @map("guest_name")
  guestPhone       String?       @map("guest_phone")
  guestEmail       String?       @map("guest_email")
  manageToken      String?       @map("manage_token")
  barberId         String        @map("barber_id") @db.Uuid
  shopId           String?       @map("shop_id") @db.Uuid
  startsAt         DateTime      @map("starts_at") @db.Timestamptz(6)
  endsAt           DateTime      @map("ends_at") @db.Timestamptz(6)
  status           BookingStatus @default(confirmed)
  totalPriceAmd    Int           @map("total_price_amd")
  totalDurationMin Int           @map("total_duration_min") @db.SmallInt
  customerNote     String?       @map("customer_note")
  cancelReason     String?       @map("cancel_reason")
  cancelledBy      CancelledBy?  @map("cancelled_by")
  reminderSentAt   DateTime?     @map("reminder_sent_at") @db.Timestamptz(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  customer User?            @relation("CustomerBookings", fields: [customerUserId], references: [id])
  barber   Barber           @relation(fields: [barberId], references: [id])
  shop     Shop?            @relation(fields: [shopId], references: [id])
  services BookingService[]
  review   Review?

  @@index([barberId, startsAt])
  @@index([customerUserId, startsAt(sort: Desc)])
  @@map("bookings")
}

// Snapshot of chosen services at booking time (price/duration frozen).
// Surrogate id because service_id is nullable (service may be deleted later)
// and a nullable column cannot be part of a primary key.
model BookingService {
  id                  String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId           String  @map("booking_id") @db.Uuid
  serviceId           String? @map("service_id") @db.Uuid
  typeSnapshot        String? @map("type_snapshot")
  nameSnapshot        String  @map("name_snapshot")
  priceAmdSnapshot    Int     @map("price_amd_snapshot")
  durationMinSnapshot Int     @map("duration_min_snapshot") @db.SmallInt

  booking Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id])

  @@index([bookingId])
  @@map("booking_services")
}

// ---------------------------------------------------------------------------
// Reviews & media
// ---------------------------------------------------------------------------

model Review {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId      String   @unique @map("booking_id") @db.Uuid
  barberId       String   @map("barber_id") @db.Uuid
  customerUserId String   @map("customer_user_id") @db.Uuid
  rating         Int      @db.SmallInt
  comment        String?
  isHidden       Boolean  @default(false) @map("is_hidden")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  barber   Barber  @relation(fields: [barberId], references: [id])
  customer User    @relation(fields: [customerUserId], references: [id])

  @@index([barberId])
  @@map("reviews")
}

model PortfolioImage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  barberId  String   @map("barber_id") @db.Uuid
  url       String
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId])
  @@map("portfolio_images")
}

model ShopPhoto {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId    String   @map("shop_id") @db.Uuid
  url       String
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("shop_photos")
}

// ---------------------------------------------------------------------------
// Notifications & favorites
// ---------------------------------------------------------------------------

model Notification {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  type      NotificationType
  channel   NotificationChannel @default(inapp)
  payload   Json                @default("{}")
  readAt    DateTime?           @map("read_at") @db.Timestamptz(6)
  sentAt    DateTime?           @map("sent_at") @db.Timestamptz(6)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model Favorite {
  userId   String @map("user_id") @db.Uuid
  barberId String @map("barber_id") @db.Uuid

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@id([userId, barberId])
  @@map("favorites")
}

// ---------------------------------------------------------------------------
// Billing (Phase 2+)
// ---------------------------------------------------------------------------

model Plan {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String         @unique
  name          String
  priceAmdMonth Int            @map("price_amd_month")
  features      Json           @default("{}")
  isActive      Boolean        @default(true) @map("is_active")
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopId             String?            @map("shop_id") @db.Uuid
  barberId           String?            @map("barber_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus @default(active)
  currentPeriodStart DateTime           @map("current_period_start") @db.Timestamptz(6)
  currentPeriodEnd   DateTime           @map("current_period_end") @db.Timestamptz(6)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  plan Plan @relation(fields: [planId], references: [id])

  @@index([shopId])
  @@index([barberId])
  @@map("subscriptions")
}
