# ---- Database (PostgreSQL via Neon) ----
# Get these from the Neon dashboard (Connect / Connection string).
#   DATABASE_URL = the POOLED string (host contains "-pooler"), used by the app
#   DIRECT_URL   = the DIRECT string (no "-pooler"), used by Prisma migrations
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/barber_shop?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/barber_shop?sslmode=require"
#
# Local Docker alternative (docker compose up -d):
#   DATABASE_URL="postgresql://barber:barber@localhost:5432/barber_shop?schema=public"
#   DIRECT_URL="postgresql://barber:barber@localhost:5432/barber_shop?schema=public"

# ---- Redis (not used yet — leave blank until caching is added) ----
REDIS_URL=""

# ---- Auth ----
# Generate strong random values, e.g.:  openssl rand -base64 48
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# ---- Object storage (Cloudflare R2 / Backblaze B2) ----
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# ---- Email (Resend / Brevo / Mailgun) ----
EMAIL_API_KEY=""
EMAIL_FROM="no-reply@barber-shop.am"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Secret that protects the Vercel Cron reminder route
CRON_SECRET=""

# ---- Test accounts (dev only; used by scripts/seed-test-accounts.sh) ----
TEST_PASSWORD="xxxxyyyy!"
TEST_CUSTOMER_EMAIL="customer@test.local"
TEST_BARBER_EMAIL="barber@test.local"
TEST_SHOP_OWNER_EMAIL="owner@test.local"
