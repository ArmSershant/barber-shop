{
  "name": "barber-shop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma db execute --file scripts/reset-db.sql --schema prisma/schema.prisma",
    "db:seed": "prisma db execute --file prisma/seed.sql --schema prisma/schema.prisma",
    "seed:test": "bash scripts/seed-test-accounts.sh",
    "make:admin": "bash scripts/make-admin.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@mantine/core": "^7.15.0",
    "@mantine/dates": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@mantine/modals": "^7.15.0",
    "@mantine/notifications": "^7.15.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "@reduxjs/toolkit": "^2.5.0",
    "@tabler/icons-react": "^3.26.0",
    "@vercel/analytics": "^1.4.1",
    "@vercel/blob": "^0.27.0",
    "@vercel/speed-insights": "^1.1.0",
    "dayjs": "^1.11.13",
    "flag-icons": "^7.2.3",
    "jose": "^5.9.6",
    "next": "^15.1.2",
    "next-intl": "^4.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-redux": "^9.2.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.2",
    "postcss": "^8.5.10",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.4.2",
    "prisma": "^6.19.3",
    "sass": "^1.83.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "postcss": ">=8.5.10"
    }
  }
}
